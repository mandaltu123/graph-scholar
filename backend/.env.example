APP_ENV=dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
LOG_JSON=false
MAX_UPLOAD_MB=50

LANDINGAI_API_KEY=
LANDINGAI_ENDPOINT=
LANDINGAI_MOCK=true

CHUNK_SIZE_CHARS=3200
CHUNK_OVERLAP_CHARS=320

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

LLAMA_BASE_URL=http://localhost:11434/v1
LLAMA_MODEL=llama3.1
LLAMA_API_KEY=
LLM_TIMEOUT_SEC=60
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

CHROMA_PERSIST_DIR=storage/chroma
CHROMA_COLLECTION=papers
DOC_INDEX_FILE=storage/docs_index.json
UPLOADS_DIR=storage/uploads
EXTRACTED_DIR=storage/extracted
